APP_NAME=laravel-docker
APP_ENV=local
APP_KEY=base64:qwFMLD3Vs3xwhbwwpj6iuoz9NJw2Wr7cNcBztXXClJw=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=dev

LOG_CHANNEL=stack
LOG_LEVEL=debug

# DB_HOST matches the service name "postgres" in docker-compose.yml —
# containers reach each other by service name, not 127.0.0.1/localhost.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# Same principle: "redis" is the service name, resolved via Docker's internal DNS.
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

VITE_APP_NAME="${APP_NAME}"
