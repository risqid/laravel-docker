APP_NAME=laravel-docker
APP_ENV=local
# Generate after copying .env.example:
# docker compose exec app php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=dev

LOG_CHANNEL=stack
LOG_LEVEL=debug

# DB_HOST uses the PgBouncer service name. Containers communicate through Docker's internal network using service names, not localhost or 127.0.0.1.
# Laravel connects to PgBouncer for connection pooling. PostgreSQL is managed internally by PgBouncer and is not intended to be accessed directly by the application.
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_CONNECTION=pgsql

# Same principle: "redis" is the service name, resolved via Docker's internal DNS.
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

VITE_APP_NAME="${APP_NAME}"
